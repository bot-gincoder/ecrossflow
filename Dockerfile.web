FROM node:22-bookworm-slim AS build

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json tsconfig.base.json .npmrc ./
COPY artifacts/ecrossflow/package.json artifacts/ecrossflow/package.json
COPY lib/api-client-react/package.json lib/api-client-react/package.json
COPY lib/api-zod/package.json lib/api-zod/package.json

RUN pnpm install --frozen-lockfile

COPY artifacts/ecrossflow artifacts/ecrossflow
COPY lib/api-client-react lib/api-client-react
COPY lib/api-zod lib/api-zod

ARG VITE_GOOGLE_CLIENT_ID=""
ARG VITE_STRIPE_PUBLIC_KEY=""
ARG BASE_PATH="/"

ENV VITE_GOOGLE_CLIENT_ID="$VITE_GOOGLE_CLIENT_ID"
ENV VITE_STRIPE_PUBLIC_KEY="$VITE_STRIPE_PUBLIC_KEY"
ENV BASE_PATH="$BASE_PATH"

RUN pnpm --filter @workspace/ecrossflow run build

FROM nginx:1.27-alpine

COPY docker/nginx-web.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/artifacts/ecrossflow/dist/public /usr/share/nginx/html

EXPOSE 80
