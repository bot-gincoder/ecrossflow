modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
SMTP_HOST = "smtp.elasticemail.com"
SMTP_PORT = "2525"
SMTP_USER = "support@ecrossflow.com"
SMTP_FROM = "support@ecrossflow.com"
TWILIO_PHONE = "+13186468032"

[nix]
channel = "stable-25_05"
