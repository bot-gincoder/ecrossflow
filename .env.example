# Domain & TLS
DOMAIN=ecrossflow.com
ACME_EMAIL=admin@ecrossflow.com

# PostgreSQL
POSTGRES_DB=ecrossflow
POSTGRES_USER=ecrossflow
POSTGRES_PASSWORD=change-me-postgres-password

# API core
JWT_SECRET=change-me-super-secret-jwt
LOG_LEVEL=info
PLATFORM_REF_CODE=ECFSTART

# Seeded admin (first boot)
ADMIN_SEED_PASSWORD=ChangeMe123!
ADMIN_SEED_EMAIL=admin@ecrossflow.com
ADMIN_SEED_REFERRAL_CODE=ECFADMIN0

# API optional integrations
GOOGLE_CLIENT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ecrossflow.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=
PAYMENT_WEBHOOK_SECRET=change-me-webhook-secret
PAYMENT_WEBHOOK_SECRET_MONCASH=
PAYMENT_WEBHOOK_SECRET_NATCASH=
PAYMENT_WEBHOOK_SECRET_CRYPTO=
PAYMENT_WEBHOOK_MAX_SKEW_SECONDS=300
MONCASH_CLIENT_ID=
MONCASH_CLIENT_SECRET=
