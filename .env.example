MONCASH_GATEWAY_BASE=https://sandbox.moncashbutton.digicelgroup.com/Moncash-middleware
MONCASH_TIMEOUT_MS=10000
MONCASH_AUTO_DEPOSIT_ENABLED=false
MONCASH_AUTO_WITHDRAW_ENABLED=false
