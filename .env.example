NOWPAYMENTS_FIXED_RATE=true
NOWPAYMENTS_FEE_PAID_BY_USER=false
NOWPAYMENTS_PAYOUT_EMAIL=
NOWPAYMENTS_PAYOUT_PASSWORD=
